# Variáveis de ambiente (configure no painel do Vercel → Settings → Environment Variables).
# Para rodar localmente com `vercel dev`, copie para .env.local e preencha.

# Senha do painel de admin (você escolhe). Sem ela, salvar fica bloqueado.
ADMIN_PASSWORD=troque-esta-senha

# Conexão do Redis (injetadas automaticamente ao adicionar a integração Upstash
# em Vercel → Storage). A função aceita os dois prefixos abaixo.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (alternativa) UPSTASH_REDIS_REST_URL=
# (alternativa) UPSTASH_REDIS_REST_TOKEN=
